# --- COMMON CONFIGS ---
ENVIRONMENT=local # Options: local, production
DATABASE_URL=sqlite:///retail_ops.db # SQLite for local fallback, or postgresql://username:password@host:port/database

# --- QUEUE / INGESTION ---
QUEUE_TYPE=local # Options: local (SQLite-based), gcp
# If using GCP Pub/Sub:
GCP_PROJECT_ID=your-gcp-project-id
GCP_PUBSUB_TOPIC=retail-ops-topic
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-credentials.json

# --- EXPERIMENT TRACKING ---
MLFLOW_TRACKING_URI=sqlite:///mlruns.db # Or http://localhost:5000
# If using DagsHub / Databricks remote MLflow:
MLFLOW_TRACKING_USERNAME=your_mlflow_username
MLFLOW_TRACKING_PASSWORD=your_mlflow_password

# --- LLM & ACTIONS (Phase 7-8) ---
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-east-1
AWS_SES_SENDER_EMAIL=sender@example.com
